# Verification configuration example
#
# Copy values into your CI secret store or local environment as needed.
# Do not commit real secrets to this repository.

# Jira and verification identifiers
JIRA_TICKET=IOS-1234
VERIFICATION_ID=IOS-1234

# Git refs
BASELINE_REF=develop
CANDIDATE_REF=b7c8627642951d53942af23e24b695dce8700a9f

# Execution mode
EXECUTION_MODE=local

# Local Xcode execution
APP_REPO_PATH=/Users/ryanthomas/Documents/GitHub/wu-ios-v2
APP_WORKSPACE=Wheels Up/Wheels Up.xcworkspace
# APP_PROJECT=Wheels Up/Wheels Up.xcodeproj
APP_SCHEME=Wheels Up
TEST_SCHEME=Wheels Up
ONLY_TESTING=WheelsUpUITests
DEVELOPER_DIR_OVERRIDE=/Applications/Xcode.app/Contents/Developer
DERIVED_DATA_PATH=/tmp/verify-fix-derived-data
CLONED_SOURCE_PACKAGES_DIR_PATH=/tmp/verify-fix-source-packages
SIMULATOR_DESTINATION=platform=iOS Simulator,name=iPhone 17
SKIP_PACKAGE_PLUGIN_VALIDATION=true
RUN_POD_INSTALL=true

# Bitrise
BITRISE_APP_ID=your_bitrise_app_id
BITRISE_TOKEN=your_bitrise_trigger_token
BUILD_WORKFLOW_ID=build_for_verification
DEPLOY_WORKFLOW_ID=deployBeta

# Simulator / environment
DEVICE_PROFILE=iPhone 17
LOCALE=en_US
TIMEZONE=America/New_York
TEST_ENVIRONMENT=staging

# Optional test credentials
TEST_USERNAME=test_user@example.com
TEST_PASSWORD=replace_me

# Artifact output
ARTIFACT_OUTPUT_DIR=artifacts
